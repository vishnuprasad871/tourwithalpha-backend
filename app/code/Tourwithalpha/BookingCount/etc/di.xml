<?xml version="1.0"?>
<!--
/**
 * Tourwithalpha BookingCount Module
 * Dependency Injection Configuration
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    
    <!-- Repository Interface Preferences -->
    <preference for="Tourwithalpha\BookingCount\Api\OfflineSalesRepositoryInterface" 
                type="Tourwithalpha\BookingCount\Model\OfflineSalesRepository"/>
    
    <!-- Data Interface Preferences -->
    <preference for="Tourwithalpha\BookingCount\Api\Data\OfflineSalesInterface" 
                type="Tourwithalpha\BookingCount\Model\OfflineSales"/>
    
    <preference for="Tourwithalpha\BookingCount\Api\Data\OfflineSalesSearchResultsInterface"
                type="Tourwithalpha\BookingCount\Model\OfflineSalesSearchResults"/>

    <!-- Enforce the booking cutoff on add-to-cart (storefront + GraphQL) -->
    <type name="Magento\Quote\Model\Quote">
        <plugin name="tourwithalpha_validate_booking_cutoff"
                type="Tourwithalpha\BookingCount\Plugin\ValidateBookingCutoff"
                sortOrder="10"/>
    </type>

</config>

