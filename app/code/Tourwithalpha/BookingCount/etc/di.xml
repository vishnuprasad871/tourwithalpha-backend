    <preference for="Tourwithalpha\BookingCount\Api\Data\OfflineSalesInterface" 
                type="Tourwithalpha\BookingCount\Model\OfflineSales"/>
    
    <preference for="Tourwithalpha\BookingCount\Api\Data\OfflineSalesSearchResultsInterface" 
                type="Tourwithalpha\BookingCount\Model\OfflineSalesSearchResults"/>
    
