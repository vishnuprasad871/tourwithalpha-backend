        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    
    <!-- Repository Interface Preferences -->
    <preference for="Tourwithalpha\BookingCount\Api\OfflineSalesRepositoryInterface" 
                type="Tourwithalpha\BookingCount\Model\OfflineSalesRepository"/>
    
